@using Microsoft.AspNetCore.Components.Authorization

@inject NavigationManager Nav

@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">AuthClient</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <!-- Home -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                Home
            </NavLink>
        </div>

        <!-- User (protected page) -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="user">
                User Info
            </NavLink>
        </div>

        <hr />

        <!-- AUTH SECTION -->
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <span class="nav-link">
                        👋 @context.User.Identity?.Name
                    </span>
                </div>

                <div class="nav-item px-3">
                    <button class="btn-link nav-link" @onclick="Logout">
                        Logout
                    </button>
                </div>
            </Authorized>

            <NotAuthorized>
                <div class="nav-item px-3">
                    <button class="btn btn-link nav-link" @onclick="Login">
                         <span class="ms-logo">
                            <span></span><span></span><span></span><span></span>
                        </span> Login with Microsoft
                    </button>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>

@code {
    void Login()
    {
        Nav.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
    }

    void Logout()
    {
        Nav.NavigateTo("MicrosoftIdentity/Account/SignOut", true);
    }
}